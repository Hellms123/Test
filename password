<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Passwort Tool</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 600px;
            margin: 40px auto;
            padding: 0 20px;
            background: #f5f5f5;
        }
        .karte {
            background: white;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 16px;
            border: 1px solid #e0e0e0;
        }
        .passwort-anzeige {
            font-family: monospace;
            font-size: 18px;
            background: #f5f5f5;
            padding: 16px;
            border-radius: 8px;
            word-break: break-all;
            margin-bottom: 12px;
        }
        button {
            width: 100%;
            padding: 12px;
            background: white;
            border: 1px solid #ccc;
            border-radius: 8px;
            cursor: pointer;
            font-size: 15px;
        }
        button:hover { background: #f5f5f5; }
        input[type="range"] { width: 100%; }
        input[type="text"] {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-size: 15px;
            box-sizing: border-box;
        }
        .staerke-balken-container {
            height: 8px;
            background: #eee;
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 8px;
        }
        .staerke-balken {
            height: 100%;
            border-radius: 4px;
            transition: width 0.3s, background 0.3s;
        }
        .hinweis {
            font-size: 13px;
            color: #888;
            margin: 4px 0;
        }
        label {
            font-size: 13px;
            color: #666;
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
        }
        .optionen {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

<div class="karte">
    <p style="font-size:13px; color:#888; margin:0 0 12px;">Passwortlänge</p>
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
        <input type="range" min="6" max="32" value="16" id="laenge"
            oninput="document.getElementById('laenge-out').textContent=this.value; aktualisierePasswort();">
        <span id="laenge-out" style="font-weight:500;">16</span>
        <span style="font-size:13px; color:#888;">Zeichen</span>
    </div>

    <div class="optionen">
        <label><input type="checkbox" id="opt-gross" checked onchange="aktualisierePasswort()"> Großbuchstaben</label>
        <label><input type="checkbox" id="opt-klein" checked onchange="aktualisierePasswort()"> Kleinbuchstaben</label>
        <label><input type="checkbox" id="opt-zahlen" checked onchange="aktualisierePasswort()"> Zahlen</label>
        <label><input type="checkbox" id="opt-sonder" checked onchange="aktualisierePasswort()"> Sonderzeichen</label>
    </div>

    <div class="passwort-anzeige" id="passwort-anzeige">Wird generiert...</div>
    <button onclick="aktualisierePasswort()">Neues Passwort generieren</button>
    <button onclick="kopierePasswort()" style="margin-top:8px;">Passwort kopieren</button>
    <p id="kopiert-meldung" style="display:none; text-align:center; color:green; font-size:13px;">Kopiert!</p>
</div>

<div class="karte">
    <p style="font-size:13px; color:#888; margin:0 0 12px;">Eigenes Passwort prüfen</p>
    <input type="text" id="manuell-input" placeholder="Passwort eingeben..."
        oninput="pruefeManuellesPasswort()">
</div>

<div class="karte">
    <p style="font-size:13px; color:#888; margin:0 0 12px;">Passwortstärke</p>
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
        <div class="staerke-balken-container" style="flex:1;">
            <div class="staerke-balken" id="staerke-balken"></div>
        </div>
        <span id="staerke-label" style="font-size:14px; font-weight:500; min-width:80px; text-align:right;"></span>
    </div>
    <div id="hinweise-container"></div>
</div>

<script>
function generierePasswort(laenge) {
    let zeichen = "";
    if (document.getElementById("opt-gross").checked) zeichen += "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    if (document.getElementById("opt-klein").checked) zeichen += "abcdefghijklmnopqrstuvwxyz";
    if (document.getElementById("opt-zahlen").checked) zeichen += "0123456789";
    if (document.getElementById("opt-sonder").checked) zeichen += "!@#$%&*";
    if (!zeichen) return "Mindestens eine Option wählen";
    let passwort = "";
    for (let i = 0; i < laenge; i++) {
        passwort += zeichen[Math.floor(Math.random() * zeichen.length)];
    }
    return passwort;
}

function pruefeStaerke(passwort) {
    let punkte = 0;
    let hinweise = [];
    if (passwort.length >= 12) punkte++; else hinweise.push("Mindestens 12 Zeichen empfohlen");
    if (/[A-Z]/.test(passwort)) punkte++; else hinweise.push("Großbuchstabe fehlt");
    if (/[a-z]/.test(passwort)) punkte++; else hinweise.push("Kleinbuchstabe fehlt");
    if (/[0-9]/.test(passwort)) punkte++; else hinweise.push("Zahl fehlt");
    if (/[!@#$%&*]/.test(passwort)) punkte++; else hinweise.push("Sonderzeichen fehlt");
    return { punkte, hinweise };
}

