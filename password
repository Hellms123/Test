function pruefeStaerke(passwort) {
    let punkte = 0;
    let hinweise = [];

    if (passwort.length >= 12) {
        punkte++;
    } else {
        hinweise.push("Passwort sollte mindestens 12 Zeichen lang sein");
    }

    if (/[A-Z]/.test(passwort)) {
        punkte++;
    } else {
        hinweise.push("Mindestens ein Großbuchstabe fehlt");
    }

    if (/[a-z]/.test(passwort)) {
        punkte++;
    } else {
        hinweise.push("Mindestens ein Kleinbuchstabe fehlt");
    }

    if (/[0-9]/.test(passwort)) {
        punkte++;
    } else {
        hinweise.push("Mindestens eine Zahl fehlt");
    }

    if (/[!@#$%&*]/.test(passwort)) {
        punkte++;
    } else {
        hinweise.push("Mindestens ein Sonderzeichen fehlt");
    }

    let staerke = "";
    if (punkte <= 2) staerke = "Schwach";
    else if (punkte <= 3) staerke = "Mittel";
    else if (punkte <= 4) staerke = "Stark";
    else staerke = "Sehr stark";

    console.log("Passwort: " + passwort);
    console.log("Stärke: " + staerke + " (" + punkte + "/5 Punkte)");

    if (hinweise.length > 0) {
        console.log("Hinweise:");
        for (let hinweis of hinweise) {
            console.log("  - " + hinweis);
        }
    }
}

